{
  "name": "amail-monorepo",
  "private": true,
  "description": "Amail — self-hosted email proxy gateway",
  "repository": {
    "type": "git",
    "url": "https://github.com/Moonrend/Amail"
  },
  "homepage": "https://github.com/Moonrend/Amail#readme",
  "bugs": {
    "url": "https://github.com/Moonrend/Amail/issues"
  },
  "author": "Moonrend",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace=@amail/server run dev",
    "build": "npm run build --workspaces --if-present",
    "start": "npm --workspace=@amail/server run start",
    "cli": "node packages/cli/dist/index.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "vitepress": "^1.6.4"
  }
}
