# Amail Configuration

# Server
PORT=3000
HOST=0.0.0.0

# Admin token for management API (set a strong random string)
ADMIN_TOKEN=change-me-to-a-secure-random-string

# Database path (relative to project root)
DB_PATH=./data/amail.db

# Encryption key for SMTP passwords/tokens (32 bytes hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Default rate limit per API key (requests per minute)
DEFAULT_RATE_LIMIT=60

# Log level (info, warn, error, debug)
LOG_LEVEL=info
