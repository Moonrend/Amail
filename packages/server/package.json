{
  "name": "@amail/server",
  "version": "1.0.0",
  "description": "Amail server — self-hosted email proxy gateway",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/Moonrend/Amail"
  },
  "homepage": "https://github.com/Moonrend/Amail#readme",
  "bugs": {
    "url": "https://github.com/Moonrend/Amail/issues"
  },
  "author": "Moonrend",
  "type": "module",
  "main": "dist/index.js",
  "keywords": [
    "amail",
    "email",
    "smtp",
    "server",
    "gateway"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && xcopy /E /Y /I src\\web dist\\web >nul 2>&1 || cp -r src/web dist/web",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate --config ../../drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ../../drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config ../../drizzle.config.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/view": "^11.1.1",
    "better-sqlite3": "^11.8.2",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.38.0",
    "ejs": "^6.0.1",
    "fastify": "^5.3.3",
    "nanoid": "^5.1.5",
    "nodemailer": "^6.10.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^22.15.21",
    "@types/nodemailer": "^6.4.17",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
