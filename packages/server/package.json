{
  "name": "@amail/server",
  "version": "1.0.0",
  "description": "Amail server — self-hosted email proxy gateway",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && xcopy /E /Y /I src\\web dist\\web >nul 2>&1 || cp -r src/web dist/web",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/view": "^11.1.1",
    "better-sqlite3": "^11.8.2",
    "dotenv": "^16.5.0",
    "ejs": "^6.0.1",
    "fastify": "^5.3.3",
    "nanoid": "^5.1.5",
    "nodemailer": "^8.0.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ejs": "^3.1.5",
    "@types/node": "^22.15.21",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
