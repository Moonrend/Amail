{
  "name": "@wydev/amail",
  "version": "1.1.7",
  "description": "Official Node.js SDK for Amail — self-hosted email proxy gateway with Resend-compatible API",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/Moonrend/Amail"
  },
  "homepage": "https://github.com/Moonrend/Amail#readme",
  "bugs": {
    "url": "https://github.com/Moonrend/Amail/issues"
  },
  "author": "Moonrend",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "devDependencies": {
    "tsdown": "^0.11.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "amail",
    "email",
    "smtp",
    "sdk",
    "resend-compatible",
    "nodejs"
  ]
}
